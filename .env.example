# ──────────────────────────────────────────────────────────────────────────
# Passionfruit — environment template.
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# ──────────────────────────────────────────────────────────────────────────

# ── Database (Drizzle connects directly to Postgres) ──
# Local Supabase exposes Postgres here by default after `npx supabase start`.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Supabase (Auth + Storage + API) ──
# After `npx supabase start`, these are printed by `npx supabase status`.
# The values below are the standard local-dev defaults.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
# Service-role key is server-only (seed script, admin ops). NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# ── AI gateway (provider-agnostic) ──
# Two providers ship: "gemini" (AI Studio API key) and "vertex" (Vertex AI on
# GCP, billed to your project's credits with much higher quota). Same model ids
# either way; switching is just this flag plus the provider's auth below.
AI_PROVIDER=gemini

# Provider: gemini (AI Studio) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Provider: vertex (Vertex AI) — no API key; uses Application Default Credentials.
#   gcloud auth application-default login
#   gcloud services enable aiplatform.googleapis.com
# Then set AI_PROVIDER=vertex and fill these:
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# "global" serves the newest models (e.g. gemini-3.5-flash); regional values
# like us-central1 also work for older models. (Ignored for AI_PROVIDER=gemini.)
GOOGLE_CLOUD_LOCATION=global

# Model routing. Swap these to change models without touching code.
# Cheap/fast model: parsing, classification, opportunity-matching.
FAST_MODEL=gemini-2.5-flash-lite
# Quality model: anything a kid or parent actually reads (mentor voice).
QUALITY_MODEL=gemini-3.5-flash
# Embeddings. gemini-embedding-001 supports a configurable output width; we pin
# it to EMBEDDING_DIMENSIONS, which MUST match the pgvector column (vector(768)).
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=768
