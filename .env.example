# ──────────────────────────────────────────────────────────────────────────
# Next in Research — environment template.
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# ──────────────────────────────────────────────────────────────────────────

# ── Database (Drizzle connects directly to Postgres) ──
# Local Supabase exposes Postgres here by default after `npx supabase start`.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Supabase (Auth + Storage + API) ──
# After `npx supabase start`, these are printed by `npx supabase status`.
# The values below are the standard local-dev defaults.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-anon-key
# Service-role key is server-only (seed script, admin ops). NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# ── AI gateway (provider-agnostic; Gemini wired by default) ──
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key

# Model routing. Swap these to change models without touching code.
# Cheap/fast model: parsing, classification, opportunity-matching.
FAST_MODEL=gemini-2.0-flash
# Quality model: anything a kid or parent actually reads (mentor voice).
QUALITY_MODEL=gemini-2.5-pro
# Embeddings (768 dims — must match the pgvector column width in the schema).
EMBEDDING_MODEL=text-embedding-004
